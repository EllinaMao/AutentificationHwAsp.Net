@model List<TaskItem>
<h2>Мои заметки</h2>

<div class="row mb-4">
	<div class="col-md-8">
		<form method="get" asp-action="Index" class="d-flex">
			<input type="text" name="search" class="form-control me-2" placeholder="Поиск по названию..." value="@Context.Request.Query["search"]" />
			<select name="isDone" class="form-select me-2" style="width: auto;">
				<option value="">Все задачи</option>
				<option value="false" selected="@(Context.Request.Query["isDone"] == "false")">Незавершенные</option>
				<option value="true" selected="@(Context.Request.Query["isDone"] == "true")">Завершенные</option>
			</select>
			<button type="submit" class="btn btn-secondary">Найти</button>
		</form>
	</div>
	<div class="col-md-4 text-end">
		@if (User.FindFirst("Company")?.Value == "Step")
		{
			<a asp-action="CorporateDocs" class="btn btn-info me-2">Корпоративные документы</a>
		}
		@if (int.Parse(User.FindFirst("Age")?.Value ?? "0") >= 18)
		{
			<a asp-action="AdultContent" class="btn btn-warning">Контент 18+</a>
		}
	</div>
</div>

<hr />

<div class="card mb-4">
	<div class="card-body">
		<h4>Добавить новую заметку</h4>
		<form asp-action="Create" method="post" class="row g-3">
			<div class="col-md-4">
				<input type="text" name="Title" class="form-control" placeholder="Заголовок" required />
			</div>
			<div class="col-md-6">
				<input type="text" name="Description" class="form-control" placeholder="Описание" />
			</div>
			<div class="col-md-2">
				<button type="submit" class="btn btn-success w-100">Добавить</button>
			</div>
		</form>
	</div>
</div>

<table class="table table-striped">
	<thead>
		<tr>
			<th style="width: 50px;">Статус</th>
			<th>Заголовок</th>
			<th>Описание</th>
			<th style="width: 150px;">Действие</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr class="@(item.IsDone ? "table-success" : "")">
				<td class="text-center">
					<form asp-action="ToggleStatus" method="post" style="display: inline;">
						<input type="hidden" name="id" value="@item.Id" />
						<input type="checkbox" name="IsDone" onchange="this.form.submit();" @(item.IsDone ? "checked" : "") />
					</form>
				</td>
				<td class="@(item.IsDone ? "text-decoration-line-through" : "")">@item.Title</td>
				<td class="@(item.IsDone ? "text-decoration-line-through text-muted" : "")">@item.Description</td>
				<td>
					<form asp-action="Delete" method="post" onsubmit="return confirm('Удалить?');">
						<input type="hidden" name="id" value="@item.Id" />
						<button type="submit" class="btn btn-danger btn-sm">Удалить</button>
					</form>
				</td>
			</tr>
		}
	</tbody>
</table>