@model RegisterViewModel
<h2>Регистрация нового пользователя</h2>

<div class="row">
	<div class="col-md-5">
		<form asp-action="Register" method="post">
			<div class="form-group mb-3">
				<label asp-for="Email">Email</label>
				<input asp-for="Email" class="form-control" placeholder="example@mail.com" />
				<span asp-validation-for="Email" class="text-danger"></span>
			</div>

			<div class="form-group mb-3">
				<label asp-for="Password">Пароль</label>
				<input asp-for="Password" type="password" class="form-control" placeholder="Введите пароль" />
				<span asp-validation-for="Password" class="text-danger"></span>
			</div>

			<div class="form-group mb-3">
				<label asp-for="PasswordConfirm">Подтвердите пароль</label>
				<input asp-for="PasswordConfirm" type="password" class="form-control" placeholder="Повторите пароль" />
				<span asp-validation-for="PasswordConfirm" class="text-danger"></span>
			</div>

			<div class="form-group mb-3">
				<label asp-for="Age">Возраст</label>
				<input asp-for="Age" type="number" class="form-control" placeholder="Ваш возраст" min="1" max="120" />
				<span asp-validation-for="Age" class="text-danger"></span>
				<small class="form-text text-muted">Необходим для доступа к разделам 18+</small>
			</div>

			<div class="form-group mb-3">
				<label asp-for="Company">Компания (необязательно)</label>
				<input asp-for="Company" class="form-control" placeholder="Например: Step" />
				<span asp-validation-for="Company" class="text-danger"></span>
				<small class="form-text text-muted">Укажите "Step" для доступа к корпоративным документам</small>
			</div>

			<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

			<button type="submit" class="btn btn-success">Создать аккаунт</button>
		</form>
		<p class="mt-3">Уже есть аккаунт? <a asp-action="Login">Войти</a></p>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}